{
    "manifest_version": 3,
    "name": "Clipboard Spoke",
    "short_name": "Clipboard",
    "description": "Enhanced clipboard monitoring for the Clipboard Spoke web app. Captures clipboard events even when the app tab is not focused.",
    "version": "0.1.0",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "clipboardRead",
        "tabs",
        "storage"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+V",
                "mac": "Command+Shift+V"
            },
            "description": "Open or focus the Clipboard Spoke tab"
        }
    },
    "action": {
        "default_title": "Open Clipboard Spoke",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "host_permissions": []
}